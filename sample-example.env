# --- SYSTEM SETTINGS ---
PROJECT_NAME=Nexus
ENV=development

# --- DATABASE SECRETS ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=nucleus_db
# Internal URL for Nucleus to use
POSTGRES_URL=postgresql+asyncpg://admin:password@postgres:5432/nucleus_db

# --- REAL-TIME ENGINE (CENTRIFUGO) ---
CENTRIFUGO_API_KEY=nexus_temp_key_2026
CENTRIFUGO_HMAC_SECRET=nexus_temp_secret
# Internal URL for Nucleus to reach the Go engine
CENTRIFUGO_API_URL=http://realtime:8000/api

# --- AI WORKER (LITELLM) ---
# Replace these with your actual keys
OPENAI_API_KEY=sk-xxxx...
ANTHROPIC_API_KEY=sk-ant-...
MODEL_NAME=gpt-4o

# Internal URL for Nucleus to reach Nexus-AI
NEXUS_AI_URL=http://nexus-ai:8000

# --- VECTOR DATABASE ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000

